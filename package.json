    "format:scss": "prettier --write 'src/**/*.scss'",
    "lint:js": "eslint 'src/**/*.{js,vue}'",
    "lint:md": "prettier --check '{*.md,docs/**/*.md,src/**/*.md}'",
    "lint:scss": "prettier --check 'src/**/*.scss'",

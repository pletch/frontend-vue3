    "eslint-plugin-vue": "^9.27.0",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.2",
    "sass": "^1.77.6",
    "vite": "^5.3.3",
    "vite-plugin-package-version": "^1.1.0",
    "vitest": "^1.6.0",
    "vitest-fetch-mock": "^0.2.2",
    "vue-eslint-parser": "^9.4.3"

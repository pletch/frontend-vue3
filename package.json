  },
  "dependencies": {
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "@vueuse/core": "^10.11.0",
    "autoprefixer": "^10.4.19",
    "deepmerge": "^4.3.1",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lucide-vue-next": "^1.0.0",
    "moment": "^2.30.1",
    "pinia": "^2.1.7",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vue": "^3.4.0",
    "vue-datepicker-next": "^1.0.3",
    "vue-i18n": "^11.0.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
